int* countBits(int n, int returnSize[]) {
    returnSize[0] = n + 1;
    int* ans = (int*)malloc((n + 1) * sizeof(int));
    for (int i = 0; i <= n; i++) {
        int count = 0;
        int num = i;
        while (num > 0) {
            count += (num % 2); 
            num = num / 2;      
        }
        ans[i] = count; 
    }   
    return ans;
}  
